# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# Ohne SMTP-Konfiguration läuft alles – Mails werden dann nur ins Log geschrieben.

# Beispiel Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=deine@gmail.com, SMTP_PASS=<App-Passwort, NICHT dein normales Passwort>
# App-Passwort erstellen: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Basis-URL für Links in Mails (lokal so lassen)
BASE_URL=http://127.0.0.1:8000

# Wie oft automatisch gescrapt wird (Stunden)
SCRAPE_INTERVAL_HOURS=6
